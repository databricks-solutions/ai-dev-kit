# Noom MCP Server — environment variables
#
# Copy this file to .env and fill in the values, or export them directly
# in the shell / MCP client config before starting noom-mcp-server.
#
# DO NOT commit .env to source control.

# ---------------------------------------------------------------------------
# SQL Service Principal credentials
#
# All SQL execution (execute_sql, execute_sql_multi) runs as this SP,
# regardless of which user is calling the MCP tool.  The SP credentials
# are infrastructure secrets — users should never need to handle them directly.
#
# Option 1 — Databricks Secrets (recommended for local users)
#
#   An admin stores the SP credentials in a Databricks secret scope once.
#   Users only configure the scope name below.  They need READ permission
#   on the scope but never see the secret values.
#
#   Admin setup (one-time):
#     databricks secrets create-scope dbrix_mcp_secret
#     databricks secrets put-secret dbrix_mcp_secret sql-sp-client-id     --string-value <id>
#     databricks secrets put-secret dbrix_mcp_secret sql-sp-client-secret --string-value <secret>
#     databricks secrets put-acl    dbrix_mcp_secret <group-or-user> READ
#
DATABRICKS_MCP_SECRET_SCOPE=dbrix_mcp_secret

# Override default secret key names (optional — defaults shown):
# DATABRICKS_MCP_SECRET_KEY_CLIENT_ID=sql-sp-client-id
# DATABRICKS_MCP_SECRET_KEY_CLIENT_SECRET=sql-sp-client-secret

# ---------------------------------------------------------------------------
# Option 2 — Direct env vars (dev / CI only, not for end users)
#
#   Only used when DATABRICKS_MCP_SECRET_SCOPE is not set.
#   Do not use this in production — the secret would be visible in the
#   process environment and shell history.
#
# DATABRICKS_MCP_SQL_CLIENT_ID=<service-principal-client-id>
# DATABRICKS_MCP_SQL_CLIENT_SECRET=<service-principal-client-secret>

# ---------------------------------------------------------------------------
# Optional: SQL workspace host override
#
# Only needed when the SQL SP lives in a different workspace than the
# calling user's workspace.
# ---------------------------------------------------------------------------

# DATABRICKS_MCP_SQL_HOST=https://your-workspace.cloud.databricks.com

# ---------------------------------------------------------------------------
# Calling user credentials (standard Databricks SDK env vars)
#
# Recommended: use browser OAuth ("databricks auth login") — no env vars needed.
# For OAuth M2M: set DATABRICKS_CLIENT_ID + DATABRICKS_CLIENT_SECRET.
# PAT (DATABRICKS_TOKEN) is explicitly rejected by noom-mcp-server.
# ---------------------------------------------------------------------------

# DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# DATABRICKS_CLIENT_ID=<user-or-app-client-id>
# DATABRICKS_CLIENT_SECRET=<user-or-app-client-secret>
